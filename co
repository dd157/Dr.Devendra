<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Dr. Devendra Singh Dandotiya | Associate Professor (Research) | Presidency University</title>
<meta name="description" content="Academic portfolio of Dr. Devendra Singh Dandotiya – Battery Thermal Management, PCM, Nanofluids, ML | Presidency University Bangalore"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,300&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════════
   DESIGN: Editorial-scholarly. Deep navy canvas,
   warm gold accents, generous negative space,
   scientific precision meets humanist warmth.
══════════════════════════════════════════════ */
:root{
  --ink: #0d1b2e;
  --ink2: #1b2d45;
  --blue: #1762b3;
  --blue2: #2176d4;
  --gold: #c89b2a;
  --gold2: #e8b83a;
  --teal: #1a8a7b;
  --muted: #6b7a90;
  --pale: #f0f4fa;
  --card: #ffffff;
  --border: #dde5f0;
  --text: #2d3748;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--pale);color:var(--text);line-height:1.7;overflow-x:hidden}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--ink)}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px}

/* ══ HERO ══════════════════════════════════ */
.hero{
  position:relative;
  background:var(--ink);
  min-height:100vh;
  display:flex;flex-direction:column;
  overflow:hidden;
}

.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(23,98,179,0.06) 1px,transparent 1px),
    linear-gradient(90deg,rgba(23,98,179,0.06) 1px,transparent 1px);
  background-size:60px 60px;
}

.hero-orb{
  position:absolute;
  border-radius:50%;
  filter:blur(90px);
  pointer-events:none;
}
.hero-orb1{width:700px;height:700px;background:radial-gradient(circle,rgba(23,98,179,0.22),transparent 70%);top:-200px;left:-200px}
.hero-orb2{width:500px;height:500px;background:radial-gradient(circle,rgba(200,155,42,0.15),transparent 70%);bottom:-100px;right:-100px}
.hero-orb3{width:300px;height:300px;background:radial-gradient(circle,rgba(26,138,123,0.12),transparent 70%);top:40%;left:55%}

/* floating particles */
.particles{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.p{position:absolute;background:var(--gold);border-radius:50%;animation:float linear infinite;opacity:0.25}
@keyframes float{0%{transform:translateY(100vh) rotate(0)}100%{transform:translateY(-20px) rotate(720deg)}}

.hero-nav{
  position:relative;z-index:10;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.6rem 3rem;
  border-bottom:1px solid rgba(255,255,255,0.07);
}

.logo{
  font-family:'DM Serif Display',serif;
  color:var(--gold);font-size:1.1rem;letter-spacing:0.5px;
}

.nav-links{display:flex;gap:0.2rem;flex-wrap:wrap}
.nav-links a{
  color:rgba(255,255,255,0.6);text-decoration:none;
  font-size:0.8rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;
  padding:0.4rem 0.9rem;border-radius:4px;
  transition:all 0.2s;
}
.nav-links a:hover{color:var(--gold);background:rgba(200,155,42,0.1)}

.hero-content{
  position:relative;z-index:5;
  flex:1;display:grid;
  grid-template-columns:1fr 380px;
  gap:4rem;align-items:center;
  padding:4rem 3rem 3rem;
  max-width:1300px;margin:0 auto;width:100%;
}

.hero-left{}

.hero-eyebrow{
  display:inline-flex;align-items:center;gap:0.6rem;
  background:rgba(200,155,42,0.12);border:1px solid rgba(200,155,42,0.3);
  border-radius:30px;padding:0.4rem 1rem;
  font-size:0.75rem;font-weight:700;color:var(--gold);letter-spacing:1.5px;text-transform:uppercase;
  margin-bottom:1.5rem;
  animation:fadeUp 0.6s ease both;
}
.hero-eyebrow::before{content:'';width:6px;height:6px;background:var(--gold);border-radius:50%;animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}

h1.hero-name{
  font-family:'DM Serif Display',serif;
  font-size:clamp(2.6rem,5vw,4.2rem);
  line-height:1.1;
  color:#fff;
  letter-spacing:-1px;
  margin-bottom:0.6rem;
  animation:fadeUp 0.6s ease 0.1s both;
}
h1.hero-name em{color:var(--gold);font-style:normal}

.hero-title{
  font-size:1.05rem;color:rgba(255,255,255,0.65);
  margin-bottom:1.2rem;
  animation:fadeUp 0.6s ease 0.2s both;
}

.hero-location{
  display:flex;align-items:center;gap:0.5rem;
  font-size:0.9rem;color:rgba(255,255,255,0.45);margin-bottom:2rem;
  animation:fadeUp 0.6s ease 0.25s both;
}

.hero-summary{
  max-width:560px;
  font-size:1rem;line-height:1.75;
  color:rgba(255,255,255,0.72);
  border-left:3px solid var(--gold);
  padding-left:1.2rem;
  margin-bottom:2.5rem;
  animation:fadeUp 0.6s ease 0.3s both;
}

.hero-cta{
  display:flex;gap:1rem;flex-wrap:wrap;
  animation:fadeUp 0.6s ease 0.35s both;
}

.btn{
  display:inline-flex;align-items:center;gap:0.5rem;
  padding:0.75rem 1.6rem;border-radius:8px;
  font-size:0.88rem;font-weight:700;letter-spacing:0.5px;
  text-decoration:none;transition:all 0.22s;cursor:pointer;border:none;
}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--ink);box-shadow:0 4px 20px rgba(200,155,42,0.35)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(200,155,42,0.5)}
.btn-outline{background:transparent;color:rgba(255,255,255,0.75);border:1px solid rgba(255,255,255,0.2)}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);background:rgba(200,155,42,0.08)}

/* STATS RIBBON */
.hero-stats{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;
  animation:fadeUp 0.6s ease 0.45s both;
}

.stat-box{
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:12px;padding:1.1rem;text-align:center;
  transition:all 0.25s;backdrop-filter:blur(4px);
}
.stat-box:hover{background:rgba(255,255,255,0.08);border-color:rgba(200,155,42,0.3);transform:translateY(-3px)}
.stat-num{font-family:'DM Serif Display',serif;font-size:2rem;color:var(--gold);line-height:1}
.stat-lbl{font-size:0.7rem;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.8px;margin-top:0.3rem}

/* PROFILE CARD */
.hero-right{animation:fadeUp 0.6s ease 0.4s both}

.profile-card{
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:20px;padding:2rem;
  backdrop-filter:blur(10px);
}

.avatar-wrap{
  width:120px;height:120px;margin:0 auto 1.5rem;
  background:linear-gradient(135deg,var(--gold),var(--blue));
  border-radius:50%;padding:3px;
}
.avatar-wrap img{width:100%;height:100%;border-radius:50%;object-fit:cover;border:3px solid var(--ink)}
.avatar-initials{
  width:100%;height:100%;border-radius:50%;
  background:var(--ink2);border:3px solid var(--ink);
  display:flex;align-items:center;justify-content:center;
  font-family:'DM Serif Display',serif;font-size:2rem;color:var(--gold);
}

.profile-links-grid{display:flex;flex-direction:column;gap:0.6rem}
.profile-link-item{
  display:flex;align-items:center;gap:0.75rem;
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.07);
  border-radius:8px;padding:0.6rem 0.9rem;
  text-decoration:none;transition:all 0.2s;
}
.profile-link-item:hover{background:rgba(200,155,42,0.1);border-color:rgba(200,155,42,0.3)}
.pli-icon{
  width:28px;height:28px;border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:0.65rem;font-weight:800;color:#fff;flex-shrink:0;
}
.pli-text{flex:1}
.pli-name{font-size:0.78rem;font-weight:700;color:#fff}
.pli-id{font-size:0.65rem;color:rgba(255,255,255,0.4)}

.hero-scroll{
  position:relative;z-index:5;
  text-align:center;padding:1.5rem;
  border-top:1px solid rgba(255,255,255,0.05);
}
.scroll-hint{
  display:inline-flex;flex-direction:column;align-items:center;gap:0.4rem;
  color:rgba(255,255,255,0.3);font-size:0.72rem;letter-spacing:1px;text-transform:uppercase;
  animation:bounce 2s ease infinite;
}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(6px)}}
.scroll-hint svg{width:16px;height:16px;stroke:currentColor;fill:none}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* ══ MAIN LAYOUT ═══════════════════════════ */
main{max-width:1300px;margin:0 auto;padding:4rem 2rem}

section{margin-bottom:5rem}

.section-header{
  display:flex;align-items:center;gap:1rem;margin-bottom:2.5rem;
}
.section-label{
  font-size:0.7rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;
  color:var(--gold);
}
.section-title{
  font-family:'DM Serif Display',serif;
  font-size:clamp(1.7rem,3vw,2.2rem);
  color:var(--ink);line-height:1.2;
}
.section-line{flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent)}

/* ── CARDS ── */
.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:16px;
  box-shadow:0 2px 20px rgba(13,27,46,0.06);
  overflow:hidden;
  transition:box-shadow 0.25s;
}
.card:hover{box-shadow:0 8px 40px rgba(13,27,46,0.12)}
.card-pad{padding:1.8rem}

/* ── EXPERIENCE TIMELINE ── */
.timeline{position:relative;padding-left:2rem}
.timeline::before{
  content:'';position:absolute;left:6px;top:0;bottom:0;
  width:2px;background:linear-gradient(to bottom,var(--gold),var(--blue),var(--teal));
  border-radius:2px;
}
.tl-item{position:relative;margin-bottom:2rem}
.tl-item:last-child{margin-bottom:0}
.tl-dot{
  position:absolute;left:-2rem;top:4px;
  width:14px;height:14px;border-radius:50%;
  background:var(--gold);border:3px solid var(--pale);
  box-shadow:0 0 0 2px var(--gold);
  z-index:1;
}
.tl-dot.blue{background:var(--blue);box-shadow:0 0 0 2px var(--blue)}
.tl-dot.teal{background:var(--teal);box-shadow:0 0 0 2px var(--teal)}
.tl-period{font-size:0.72rem;font-weight:700;color:var(--blue);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:0.2rem}
.tl-role{font-family:'DM Serif Display',serif;font-size:1.1rem;color:var(--ink);margin-bottom:0.1rem}
.tl-org{font-size:0.9rem;color:var(--muted)}

/* ── PUBLICATIONS ── */
.pub-year-group{margin-bottom:1.5rem}
.pub-year-badge{
  display:inline-block;
  background:var(--ink);color:var(--gold);
  font-family:'DM Serif Display',serif;font-size:1rem;
  padding:0.2rem 0.9rem;border-radius:6px;margin-bottom:1rem;
}
.pub-item{
  border-left:3px solid var(--border);
  padding:0.85rem 1rem;margin-bottom:0.6rem;
  border-radius:0 8px 8px 0;background:#fafbfe;
  transition:border-color 0.2s,background 0.2s;
  cursor:default;
}
.pub-item:hover{border-color:var(--blue);background:#f0f5ff}
.pub-title{font-size:0.9rem;font-weight:600;color:var(--ink);line-height:1.4;margin-bottom:0.3rem}
.pub-meta{font-size:0.78rem;color:var(--muted)}
.pub-tags{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:0.4rem}
.qtag{
  font-size:0.66rem;font-weight:800;letter-spacing:0.5px;
  padding:0.15rem 0.55rem;border-radius:20px;
}
.qtag.q1{background:#dcfce7;color:#15803d}
.qtag.q2{background:#dbeafe;color:#1d4ed8}
.qtag.q3{background:#fef3c7;color:#b45309}
.qtag.q4{background:#f3f4f6;color:#6b7280}
.qtag.pick{background:#fde68a;color:#92400e}
.qtag.scie{background:#ede9fe;color:#7c3aed}
.qtag.scopus{background:#ffedd5;color:#c2410c}
.qtag.esci{background:#cffafe;color:#0e7490}

/* Pub filter */
.pub-filter{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem}
.pfbtn{
  padding:0.4rem 1rem;border-radius:20px;font-size:0.78rem;font-weight:700;
  border:1px solid var(--border);background:#fff;color:var(--muted);cursor:pointer;
  transition:all 0.2s;
}
.pfbtn.active,.pfbtn:hover{background:var(--ink);color:var(--gold);border-color:var(--ink)}

/* ── PROJECTS ── */
.projects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.2rem}
.proj-card{
  background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.5rem;transition:all 0.25s;position:relative;overflow:hidden;
}
.proj-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;
  background:linear-gradient(90deg,var(--gold),var(--blue));
}
.proj-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(13,27,46,0.12)}
.proj-amount{
  font-family:'DM Serif Display',serif;font-size:2rem;color:var(--gold);
  margin-bottom:0.4rem;
}
.proj-title{font-size:0.95rem;font-weight:700;color:var(--ink);line-height:1.4;margin-bottom:0.6rem}
.proj-agency{font-size:0.8rem;color:var(--muted);margin-bottom:0.8rem}
.proj-meta{display:flex;align-items:center;justify-content:space-between}
.proj-period{font-size:0.75rem;color:var(--muted)}
.proj-badge{
  font-size:0.7rem;font-weight:800;letter-spacing:0.5px;text-transform:uppercase;
  padding:0.2rem 0.6rem;border-radius:20px;
}
.proj-badge.ongoing{background:#dcfce7;color:#15803d}
.proj-badge.done{background:#f3f4f6;color:#6b7280}

/* ── METRICS ── */
.metrics-strip{
  display:grid;grid-template-columns:repeat(6,1fr);gap:1rem;
  padding:2rem;background:var(--ink);border-radius:18px;
  margin-bottom:2.5rem;
}
.metric-item{text-align:center}
.metric-num{font-family:'DM Serif Display',serif;font-size:2.2rem;color:var(--gold);line-height:1}
.metric-lbl{font-size:0.68rem;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.8px;margin-top:0.4rem}

/* ── PROFILE CARDS GRID ── */
.profiles-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem}
.profile-card-item{
  background:var(--card);border:1px solid var(--border);border-radius:12px;
  padding:1.2rem 1.4rem;display:flex;align-items:center;gap:1rem;
  text-decoration:none;transition:all 0.22s;
}
.profile-card-item:hover{border-color:var(--blue);box-shadow:0 4px 20px rgba(23,98,179,0.12);transform:translateX(4px)}
.pci-icon{
  width:44px;height:44px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:0.75rem;font-weight:800;color:#fff;flex-shrink:0;
}
.pci-name{font-size:0.9rem;font-weight:700;color:var(--ink)}
.pci-id{font-size:0.72rem;color:var(--muted);margin-top:0.1rem}
.pci-meta{font-size:0.7rem;color:var(--blue);font-weight:600;margin-top:0.2rem}

/* ── SUPERVISION ── */
.sup-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
.sup-card{
  background:var(--card);border:1px solid var(--border);border-radius:12px;
  padding:1.3rem;transition:all 0.2s;
}
.sup-card:hover{border-color:var(--teal);transform:translateY(-2px)}
.sup-name{font-weight:700;color:var(--ink);font-size:0.92rem;margin-bottom:0.2rem}
.sup-period{font-size:0.75rem;color:var(--blue);font-weight:600}
.sup-title{font-size:0.8rem;color:var(--muted);margin-top:0.4rem;line-height:1.4}
.sup-status{
  display:inline-block;margin-top:0.5rem;
  font-size:0.68rem;font-weight:800;letter-spacing:0.5px;text-transform:uppercase;
  padding:0.15rem 0.6rem;border-radius:20px;
}
.sup-status.done{background:#dcfce7;color:#15803d}
.sup-status.ongoing{background:#dbeafe;color:#1d4ed8}

/* ── AWARDS ── */
.awards-list{display:flex;flex-direction:column;gap:0.8rem}
.award-item{
  display:flex;gap:1rem;align-items:flex-start;
  background:var(--card);border:1px solid var(--border);border-radius:10px;padding:1rem 1.2rem;
  transition:all 0.2s;
}
.award-item:hover{border-color:var(--gold);background:#fffbf0}
.award-icon{font-size:1.4rem;flex-shrink:0;margin-top:0.1rem}
.award-text{font-size:0.88rem;color:var(--text);line-height:1.5}

/* ── PATENTS ── */
.patents-list{display:flex;flex-direction:column;gap:0.9rem}
.patent-card{
  background:var(--card);border:1px solid var(--border);border-radius:12px;
  padding:1.2rem 1.4rem;display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:start;
  transition:all 0.2s;
}
.patent-card:hover{border-color:var(--gold);box-shadow:0 4px 20px rgba(200,155,42,0.1)}
.patent-num{
  font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--gold);
  line-height:1;opacity:0.3;
}
.patent-title{font-weight:700;color:var(--ink);font-size:0.92rem;margin-bottom:0.3rem}
.patent-meta{font-size:0.78rem;color:var(--muted)}
.patent-badge{
  font-size:0.7rem;font-weight:800;padding:0.25rem 0.7rem;border-radius:6px;white-space:nowrap;
}
.patent-badge.granted{background:#dcfce7;color:#15803d}
.patent-badge.published{background:#dbeafe;color:#1d4ed8}

/* ── REVIEWER ── */
.reviewer-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.8rem}
.rev-card{
  background:var(--card);border:1px solid var(--border);border-radius:10px;padding:1rem;
}
.rev-pub{font-weight:700;color:var(--ink);font-size:0.85rem;margin-bottom:0.4rem}
.rev-journals{font-size:0.75rem;color:var(--muted);line-height:1.5}

/* ── CONTACT ── */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.contact-item{
  display:flex;align-items:center;gap:1rem;
  background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.2rem;
}
.ci-icon{
  width:44px;height:44px;background:var(--ink);border-radius:10px;
  display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;
}
.ci-lbl{font-size:0.7rem;text-transform:uppercase;letter-spacing:0.8px;color:var(--muted);margin-bottom:0.2rem}
.ci-val{font-size:0.9rem;font-weight:600;color:var(--ink)}
.ci-val a{color:var(--blue);text-decoration:none}
.ci-val a:hover{text-decoration:underline}

/* ── BACK TO TOP ── */
#btt{
  position:fixed;bottom:2rem;right:2rem;
  width:44px;height:44px;background:var(--ink);border:1px solid rgba(255,255,255,0.1);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  cursor:pointer;z-index:999;
  transition:all 0.25s;opacity:0;pointer-events:none;
  color:var(--gold);font-size:1.2rem;
  box-shadow:0 4px 20px rgba(0,0,0,0.3);
}
#btt.visible{opacity:1;pointer-events:all}
#btt:hover{transform:translateY(-3px);background:var(--gold);color:var(--ink)}

/* ── TABS ── */
.tab-bar{display:flex;gap:0.3rem;border-bottom:2px solid var(--border);margin-bottom:1.5rem}
.tab{
  padding:0.6rem 1.2rem;font-size:0.82rem;font-weight:700;cursor:pointer;
  border-bottom:2px solid transparent;margin-bottom:-2px;color:var(--muted);
  transition:all 0.2s;border-radius:6px 6px 0 0;
}
.tab.active,.tab:hover{color:var(--blue);border-bottom-color:var(--blue)}
.tab-content{display:none}
.tab-content.active{display:block}

/* ── FOOTER ── */
footer{
  background:var(--ink);color:rgba(255,255,255,0.5);
  text-align:center;padding:3rem 2rem;
  font-size:0.82rem;
}
footer strong{color:var(--gold)}

