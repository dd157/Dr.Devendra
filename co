<script>
// ── PARTICLES ──────────────────────────────────────────
(function(){
  const c = document.getElementById('particles');
  for(let i=0;i<20;i++){
    const p = document.createElement('div');
    p.className='p';
    const s = Math.random()*4+2;
    p.style.cssText=`width:${s}px;height:${s}px;left:${Math.random()*100}%;animation-duration:${Math.random()*20+15}s;animation-delay:${Math.random()*-20}s;opacity:${Math.random()*0.2+0.05}`;
    c.appendChild(p);
  }
})();

// ── SCROLL REVEAL ─────────────────────────────────────
const observer = new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in')}});
},{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));

// ── BACK TO TOP ───────────────────────────────────────
const btt = document.getElementById('btt');
window.addEventListener('scroll',()=>{
  btt.classList.toggle('visible', window.scrollY > 400);
});

// ── TABS ──────────────────────────────────────────────
function switchTab(btn, id){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(id).classList.add('active');
}

// ── PUB FILTER ────────────────────────────────────────
function filterPubs(btn, filter){
  document.querySelectorAll('.pfbtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#pub-list .pub-item').forEach(item=>{
    const tags = item.dataset.tags || '';
    if(filter==='all' || tags.includes(filter)){
      item.style.display='';
    } else {
      item.style.display='none';
    }
  });
  // hide/show year groups that are empty
  document.querySelectorAll('.pub-year-group').forEach(g=>{
    const visible = [...g.querySelectorAll('.pub-item')].some(i=>i.style.display!=='none');
    g.style.display = visible ? '' : 'none';
  });
}

// ── COUNTER ANIMATION ─────────────────────────────────
function animateCounters(){
  document.querySelectorAll('.stat-num,.metric-num').forEach(el=>{
    const text = el.textContent;
    const num = parseFloat(text.replace(/[^0-9.]/g,''));
    if(!num) return;
    const prefix = text.match(/[₹]/)?.[0] || '';
    const suffix = text.match(/[+L]/)?.[0] || '';
    let current = 0; const steps = 40;
    const inc = num/steps;
    const t = setInterval(()=>{
      current = Math.min(current+inc, num);
      el.textContent = prefix + (Number.isInteger(num)?Math.round(current):current.toFixed(1)) + suffix;
      if(current>=num) clearInterval(t);
    }, 40);
  });
}
const heroObs = new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){animateCounters();heroObs.disconnect();}
},{threshold:0.3});
heroObs.observe(document.querySelector('.hero-stats'));
</script>
